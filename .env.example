# ─────────────────────────────────────────────────────────────
# Flatfox app — environment template. Copy to .env and fill in.
#   cp .env.example .env
# Both /app (Next.js) and /worker (Python) read from this file.
# Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Shared ──────────────────────────────────────────────────
# Matches docker-compose.yml service credentials for local dev.
DATABASE_URL=postgresql://flatfox:flatfox@localhost:5432/flatfox
REDIS_URL=redis://localhost:6379

# ── Next.js (/app) ──────────────────────────────────────────
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=sk-ant-...          # on-demand AI: profile parsing + message drafting

# ── Python worker (/worker) ─────────────────────────────────
# ANTHROPIC_API_KEY is shared (see above) — used for batch listing extraction.
INGESTION_INTERVAL_MINUTES=30
MATCH_SCORE_THRESHOLD=0.5

# Flatfox API (verified live 2026-06-03 — see PROJECT-PLAN §3)
FLATFOX_BASE_URL=https://flatfox.ch
FLATFOX_PAGE_LIMIT=100                 # API max page size (limit/offset pagination)
FLATFOX_EXPAND=images,documents,attributes   # required to resolve image IDs -> objects
FLATFOX_PAGE_DELAY_SECONDS=0.5         # polite delay between pages (no rate limit observed)
# Only ingest rentable housing; skip parking/commercial (~40% of the feed)
FLATFOX_OFFER_TYPES=RENT
FLATFOX_CATEGORIES=APARTMENT,SHARED,HOUSE
