// Prisma schema — single source of truth for the database (PROJECT-PLAN §6).
//
// This scaffold defines only the datasource + generator so `prisma generate`
// succeeds and lib/db.ts type-checks. The full model set (users, user_profiles,
// listings, listing_attributes, matches, messages) is added in Task #2.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [cube, earthdistance]
}
